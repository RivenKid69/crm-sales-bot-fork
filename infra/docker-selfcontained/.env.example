API_KEY=replace-with-long-random-secret

OLLAMA_IMAGE=ollama/ollama:0.17.7
OLLAMA_MODEL=qwen3.5:27b

TEI_EMBED_MODEL_ID=Qwen/Qwen3-Embedding-4B
TEI_EMBED_REVISION=5cf2132abc99cad020ac570b19d031efec650f2b
TEI_RERANK_MODEL_ID=Qwen/Qwen3-Reranker-4B
TEI_RERANK_REVISION=f16fc5d5d2b9b1d0db8280929242745d79794ef5

DB_PATH=/app/data/conversations.db
EMBEDDING_CACHE_DIR=/app/data/embeddings-cache
STARTUP_WARMUP_ENABLED=1
SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=5000
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=3
LOG_FORMAT=readable
SESSION_LOCK_DIR=/tmp/crm_sales_bot_session_locks
SNAPSHOT_BUFFER_PATH=snapshots.db

MEDIA_MAX_ATTACHMENTS=6
MEDIA_MAX_INLINE_BYTES=15728640
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=20
MEDIA_MAX_DOCUMENT_CHARS=12000
MEDIA_MAX_SUMMARY_CHARS=2200
MEDIA_MAX_VIDEO_FRAMES=4
MEDIA_MAX_DOWNLOAD_REDIRECTS=3
MEDIA_MAX_TABLE_SHEETS=5
MEDIA_MAX_TABLE_ROWS=200
MEDIA_MAX_TABLE_COLS=20
MEDIA_MAX_PRESENTATION_SLIDES=30
MEDIA_STT_MODEL=large-v3-turbo
MEDIA_STT_LANGUAGE=ru
MEDIA_STT_BEAM_SIZE=5
MEDIA_STT_DEVICE=auto
MEDIA_STT_COMPUTE_TYPE=

# Any FF_<FLAG_NAME> from src/feature_flags.py is supported.
# Example:
# FF_AUTONOMOUS_FLOW=false
